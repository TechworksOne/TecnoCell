# =============================================================
#  .env.docker  —  Variables para docker-compose (MySQL)
# =============================================================
#  Copiar como .env antes de levantar:
#    cp .env.docker .env
#
#  ¡CAMBIA las contraseñas antes de usar en producción!
# =============================================================

# Contraseña root de MySQL (solo para el contenedor)
DB_ROOT_PASSWORD=rootpassword_CAMBIA_ESTO

# Base de datos de la aplicación
DB_NAME=tecnocell_web

# Usuario de la aplicación (NO usar root en producción)
DB_USER=tecnocell_user
DB_PASSWORD=tecnocell_pass_CAMBIA_ESTO
